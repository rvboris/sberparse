{
  "name": "@rvboris/sberparse",
  "version": "1.2.2",
  "description": "Конвертация выписок Сбербанка из PDF в JSON/CSV",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    }
  },
  "bin": {
    "sberparse": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "lint:ci": "biome check .",
    "prepublishOnly": "pnpm run test:run && pnpm run lint && pnpm run typecheck && pnpm run build"
  },
  "keywords": [
    "sberbank",
    "pdf",
    "parser",
    "csv",
    "json",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rvboris/sberparse"
  },
  "bugs": {
    "url": "https://github.com/rvboris/sberparse/issues"
  },
  "homepage": "https://github.com/rvboris/sberparse#readme",
  "author": "rvboris",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@logtape/logtape": "^2.0.5",
    "@logtape/pretty": "^2.0.5",
    "@oclif/core": "^4.10.5",
    "decimal.js": "^10.6.0",
    "fast-csv": "^5.0.5",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "oclif": {
    "bin": "sberparse",
    "commands": {
      "strategy": "single",
      "target": "./dist/commands/index.js"
    }
  },
  "packageManager": "pnpm@10.30.2"
}
